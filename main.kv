<Manager>:
    #manager: manager
    LoginScreen:
    RegisterScreen:
    MapScreen:


<LoginScreen>:
    MDCard:
        size_hint: None, None
        size: 300, 400
        pos_hint: {"center_x": 0.5, "center_y": 0.5}
        elevation: 5
        padding: 25
        spacing: 25
        orientation: 'vertical'
        
        MDBoxLayout:
            orientation: "vertical"
            halign: "center"
            MDLabel:    
                text: "Login"
                size: 10, 10
            MDGridLayout:
                cols: 2
                MDIcon:
                    icon: "account"
                    pos_hint: self.pos_hint
                MDTextField:
                    #mode: "rectangle"
                    id: login_username
                    hint_text: "Username"
                    helper_text: "Invalid Username"
                    helper_text_mode: "on_error"
                    on_text_validate: login_password.focus = True
                    #pos_hint: {"center_y": .5}
                MDIcon:
                    icon: "key-variant"
                MDTextField:
                    id: login_password
                    hint_text: "Password"
                    helper_text: "Invalid Password"
                    helper_text_mode: "on_error"
                    password: True
                    on_text_validate: root.login(login_username.text, login_password.text)
            MDLabel:
            MDGridLayout:
                #orientation: "horizontal"
                cols: 3
                MDRaisedButton:
                    text: "Clear"
                    md_bg_color: "green"
                    on_press: root.clear()
                MDLabel:
                MDRaisedButton:
                    text: "Login"
                    md_bg_color: "green"
                    on_press: root.login(login_username.text, login_password.text)
                    #on_release: app.

<RegisterScreen>:
    MDCard:
        size_hint: None, None
        size: 300, 400
        pos_hint: {"center_x": 0.5, "center_y": 0.5}
        elevation: 10
        padding: 25
        spacing: 25
        orientation: 'vertical'
        MDBoxLayout:
            orientation: "vertical"
            halign: "center"
            MDLabel:    
                text: "Register"
                size: 10, 10  
            MDGridLayout:
                cols: 2
                MDIcon:


<MapScreen>:
    name: "mapscreen"
    on_enter: print("Hi!!!")
    MDBackdrop:
        id: backdrop
        left_action_items: [['map-marker', lambda x: self.open()]]
        title: "[b]Your current location:[/b] SRM Tech Park"
        radius_left: "25dp"
        radius_right: "0dp"
        header_text: "Farmers Near You"

        MDBackdropBackLayer:
            MyBackdropBackLayer:
                id: backlayer

        MDBackdropFrontLayer:
            MyBackdropFrontLayer:
                backdrop: backdrop

<MyBackdropBackLayer@RelativeLayout>
    MapView:
        id: mapview
        lat: 12.8248319
        lon: 80.0450381
        zoom: 13
        #size_hint: .5, .5
        #pos_hint: {"x": .25, "y": .25}
        #on_map_relocated: mapview2.sync_to(self)
        #on_map_relocated: mapview3.sync_to(self)
        MapMarker:
            source: "f1.jpg"
            size: 50, 50
            lat: 12.8798
            lon: 80.0808
        MapMarker:
            source: "f2.jpg"
            size: 50, 50
            lat: 12.8439
            lon: 80.0597
        MapMarker:
            source: "f3.png"
            size: 50, 50
            lat: 12.6819
            lon: 79.9888
        MapMarker:
            lat: 12.8248319
            lon: 80.0450381
